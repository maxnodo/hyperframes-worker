# Supabase / Lovable Cloud
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=videos

# Worker
POLL_INTERVAL_MS=5000
WORK_DIR=/tmp/hyperframes
# Cuántos jobs procesa en paralelo (1 = secuencial)
CONCURRENCY=1
# Timeout máximo de un render (ms)
RENDER_TIMEOUT_MS=600000

# HyperFrames (placeholder por ahora — añadir cuando se integre)
# HYPERFRAMES_API_URL=
# HYPERFRAMES_API_KEY=
